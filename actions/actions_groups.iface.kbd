(defvar
  ;; @start@ ====== DON'T REMOVE THIS LINE =================================

  ;; == !tabs/groups =====================================================

  ;; !tabs + spc
  action_!tabs+spc (t! unmod_all (switch ;;@iface@
    ((input virtual vk_nvim)) $nvim_action_!tabs+spc break
    ((input virtual vk_chrome)) $chrome_action_!tabs+spc break
    ((input virtual vk_obsidian)) $obsidian_action_!tabs+spc break
    ((input virtual vk_firefox)) $firefox_action_!tabs+spc break
    ((input virtual vk_tmux)) $tmux_action_!tabs+spc break
    ((input virtual vk_zellij)) $zellij_action_!tabs+spc break
    () XX break
  ))

  ;; !tabs + l | !tabs + right  
  ~action_!tabs_next (t! unmod_all (switch ;;@iface@
    ((input virtual vk_zellij)) $zellij_action_!tabs_next break
    ((input virtual vk_tmux)) $tmux_action_!tabs_next break
    ((input virtual vk_firefox)) $firefox_action_!tabs_next break
    ((input virtual vk_obsidian)) $obsidian_action_!tabs_next break
    ((input virtual vk_chrome)) $chrome_action_!tabs_next break
    ((input virtual vk_nvim)) $nvim_action_!tabs_next break
    () C-tab break
  )) 
  ;; !tabs + h | !tabs + left  
  ~action_!tabs_prev (t! unmod_all (switch ;;@iface@
    ((input virtual vk_zellij)) $zellij_action_!tabs_prev break
    ((input virtual vk_tmux)) $tmux_action_!tabs_prev break
    ((input virtual vk_firefox)) $firefox_action_!tabs_prev break
    ((input virtual vk_obsidian)) $obsidian_action_!tabs_prev break
    ((input virtual vk_chrome)) $chrome_action_!tabs_prev break
    ((input virtual vk_nvim)) $nvim_action_!tabs_prev break
    () C-S-tab break
  ))
  ;; !tabs + j | !tabs + down
  ~action_!tabs_first  (t! unmod_all (switch ;;@iface@
    () XX break
  ))
  ;; !tabs + k | !tabs + up
  ~action_!tabs_last  (t! unmod_all (switch ;;@iface@
    () XX break
  ))

  ;; !tabs + t 
  ~action_!tabs_new (t! unmod_all (switch ;;@iface@
    ((input virtual vk_tmux)) $tmux_action_!tabs_new break
    ((input virtual vk_firefox)) $firefox_action_!tabs_new break
    ((input virtual vk_obsidian)) $obsidian_action_!tabs_new break
    ((input virtual vk_chrome)) $chrome_action_!tabs_new break
    () XX break
  ))
  ;; !tabs + w
  ~action_!tabs_close (t! unmod_all (switch ;;@iface@
    ((input virtual vk_tmux)) $tmux_action_!tabs_close break
    ((input virtual vk_firefox)) $firefox_action_!tabs_close break
    ((input virtual vk_obsidian)) $obsidian_action_!tabs_close break
    ((input virtual vk_chrome)) $chrome_action_!tabs_close break
    ((input virtual vk_nvim)) $nvim_action_!tabs_close break
    () XX break
  ))
  ;; !tabs + lsft + t 
  ~action_!tabs_undo_close (t! unmod_all (switch ;;@iface@
    ((input virtual vk_firefox)) $firefox_action_!tabs_undo_close break
    ((input virtual vk_obsidian)) $obsidian_action_!tabs_undo_close break
    ((input virtual vk_chrome)) $chrome_action_!tabs_undo_close break
    () XX break
  ))

