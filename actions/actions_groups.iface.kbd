  ))
  ;; !tabs + 6
  ~action_!tabs_goto_6 (t! unmod_all (switch ;;@iface@
    ((input virtual vk_tmux)) $tmux_action_!tabs_goto_6 break
    ((input virtual vk_firefox)) $firefox_action_!tabs_goto_6 break
    ((input virtual vk_obsidian)) $obsidian_action_!tabs_goto_6 break
    ((input virtual vk_chrome)) $chrome_action_!tabs_goto_6 break
    ((input virtual vk_nvim)) $nvim_action_!tabs_goto_6 break
    () XX break
  ))
  ;; !tabs + 7
  ~action_!tabs_goto_7 (t! unmod_all (switch ;;@iface@
    ((input virtual vk_tmux)) $tmux_action_!tabs_goto_7 break
    ((input virtual vk_firefox)) $firefox_action_!tabs_goto_7 break
    ((input virtual vk_obsidian)) $obsidian_action_!tabs_goto_7 break
    ((input virtual vk_chrome)) $chrome_action_!tabs_goto_7 break
    ((input virtual vk_nvim)) $nvim_action_!tabs_goto_7 break
    () XX break
  ))
  ;; !tabs + 8
  ~action_!tabs_goto_8 (t! unmod_all (switch ;;@iface@
    ((input virtual vk_tmux)) $tmux_action_!tabs_goto_8 break
    ((input virtual vk_firefox)) $firefox_action_!tabs_goto_8 break
    ((input virtual vk_obsidian)) $obsidian_action_!tabs_goto_8 break
    ((input virtual vk_chrome)) $chrome_action_!tabs_goto_8 break
    ((input virtual vk_nvim)) $nvim_action_!tabs_goto_8 break
    () XX break
  ))
  ;; !tabs + 9
  ~action_!tabs_goto_last (t! unmod_all (switch ;;@iface@
    ((input virtual vk_tmux)) $tmux_action_!tabs_goto_last break
    ((input virtual vk_firefox)) $firefox_action_!tabs_goto_last break
    ((input virtual vk_obsidian)) $obsidian_action_!tabs_goto_last break
    ((input virtual vk_chrome)) $chrome_action_!tabs_goto_last break
    ((input virtual vk_nvim)) $nvim_action_!tabs_goto_last break
    () XX break
  ))

  ;; == !tabs + toggle =====================================================
  ;; !tabs + toggle
  ~action_!tabs+toggle (t! unmod_all (switch ;;@iface@
    ((input virtual vk_zellij)) $zellij_action_!tabs+toggle break
    ((input virtual vk_tmux)) $tmux_action_!tabs+toggle break
    ((input virtual vk_firefox)) $firefox_action_!tabs+toggle break
    ((input virtual vk_obsidian)) $obsidian_action_!tabs+toggle break
    ((input virtual vk_chrome)) $chrome_action_!tabs+toggle break
    ((input virtual vk_nvim)) $nvim_action_!tabs+toggle break
    () XX break
  ))

  ;; == !tabs + move =====================================================
  ;; !tabs + move + h | !tabs + move + left
  ~action_!tabs_move_left (t! unmod_all (switch ;;@iface@
    ((input virtual vk_tmux)) $tmux_action_!tabs_move_left break
    () XX break
  ))
  ;; !tabs + move + l | !tabs + move + right
  ~action_!tabs_move_right (t! unmod_all (switch ;;@iface@
    ((input virtual vk_tmux)) $tmux_action_!tabs_move_right break
    () XX break
  ))
  ;; !tabs + move + k | !tabs + move + up
  ~action_!tabs_move_first (t! unmod_all (switch ;;@iface@
    () XX break
  ))
  ;; !tabs + move + j | !tabs + move + down
  ~action_!tabs_move_last (t! unmod_all (switch ;;@iface@
    () XX break
  ))

)
