  ~action_!tabs_goto_5 (t! unmod_all (switch ;;@iface@
    ((input virtual vk_tmux)) $tmux_action_!tabs_goto_5 break
    ((input virtual vk_firefox)) $firefox_action_!tabs_goto_5 break
    ((input virtual vk_obsidian)) $obsidian_action_!tabs_goto_5 break
    ((input virtual vk_chrome)) $chrome_action_!tabs_goto_5 break
    ((input virtual vk_nvim)) $nvim_action_!tabs_goto_5 break
