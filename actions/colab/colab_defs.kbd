(defvar
colab_esc              C-c
colab_delete           (macro C-m d)
colab_keybindings      (macro C-m h)
colab_next_cell        (macro C-m down)
colab_prev_cell        (macro C-m up)
colab_command_palette  (macro C-S-p)
colab_move_cell_down   (macro C-m j)
colab_move_cell_up     (macro C-m k)
colab_new_cell_below   (macro C-m b)
colab_new_cell_above   (macro C-m a)
)
