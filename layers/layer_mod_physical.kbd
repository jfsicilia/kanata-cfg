;; "" LMET_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lmet_layer)
  (t! map_layers "$action_lmet" "lmet" ($<lctl $>lctl $<lalt $>lalt $lsft $rsft $!lctl $!lalt lsft rsft))
  (t! map_keys   "$action_lmet"        ($<lctl $>lctl $<lalt $>lalt $lsft $rsft tab))

  ;; lmet+tab mimics original lctl+tab functionality (typically next tab in 
  ;; browsers and editors).
  tab $action_tabs_next
) 
(deflayermap (lmet+lsft_layer)
  (t! map_layers "$action_lmet+lsft" "lmet+lsft" ($<lctl $>lctl $<lalt $>lalt $!lctl $!lalt))
  (t! map_keys   "$action_lmet+lsft"             ($<lctl $>lctl $<lalt $>lalt tab))

  tab $action_tabs_prev
)

;; "" LMET+RSFT_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""
