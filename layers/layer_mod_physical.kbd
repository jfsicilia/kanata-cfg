;; "" LALT_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lalt_layer)
  (t! map_layers "$action_lalt" "lalt" ($<lctl $>lctl $<lmet $>lmet $lsft $rsft $!lctl $!lmet lsft rsft))
  (t! map_keys   "$action_lalt"        ($<lctl $>lctl $<lmet $>lmet $lsft $rsft))

  tab $action_apps_walk_through_same_app 
) 
(deflayermap (lalt+lsft_layer)
  (t! map_layers "$action_lalt+lsft" "lalt+lsft" ($<lctl $>lctl $<lmet $>lmet $!lctl $!lmet))
  (t! map_keys   "$action_lalt+lsft"             ($<lctl $>lctl $<lmet $>lmet))
)
(deflayermap (lalt+rsft_layer)
