;; Actions
(deflayermap (spc+modA_layer)
  a $action_modA+modA
  _ XX
)

;; Bookmarks
(deflayermap (spc+modB_layer)
  b $action_modB+modB
  _ XX
)

;; Calendar
(deflayermap (spc+modC_layer)
  c $action_modC+modC
  _ XX
)

;; Definitions
(deflayermap (spc+modD_layer)
  d $action_modD+modD
  _ XX
)

;; Explorer
(deflayermap (spc+modE_layer)
  e $action_modE+modE
  _ XX
)

;; Filter
(deflayermap (spc+modF_layer)
  f $action_modF+modF
  _ XX
)

;; Git
(deflayermap (spc+modG_layer)
  g $action_modG+modG
  l $action_modG+modL
  _ XX
)

;; Hyperlinks
(deflayermap (spc+modH_layer)
  h $action_modH+modH
  _ XX
)

;; AI
(deflayermap (spc+modI_layer)
  i $action_modI+modI
  _ XX
)

;; Jumps
(deflayermap (spc+modJ_layer)
  j $action_modJ+modJ
  _ XX
)

;; Keymaps
(deflayermap (spc+modK_layer)
  k $action_modK+modK
  _ XX
)

;; Locations
(deflayermap (spc+modL_layer)
  l $action_modL+modL
  _ XX
)

;; Mem
(deflayermap (spc+modM_layer)
  m $action_modM+modM
  _ XX
)

;; Notebooks
(deflayermap (spc+modN_layer)
  n $action_modN+modN
  _ XX
)

;; Output
(deflayermap (spc+modO_layer)
  o $action_modO+modO
  _ XX
)

;; Properties
(deflayermap (spc+modP_layer)
  p $action_modP+modP
  _ XX
)

;; Quickfix
(deflayermap (spc+modQ_layer)
  q $action_modQ+modQ
  _ XX
)

;; References
(deflayermap (spc+modR_layer)
  r $action_modR+modR
  _ XX
)

;; Symbols
(deflayermap (spc+modS_layer)
  s $action_modS+modS
  _ XX
)

;; Terminal
(deflayermap (spc+modT_layer)
  t $action_modT+modT
  _ XX
)

;; UI
(deflayermap (spc+modU_layer)
  u $action_modU+modU
  _ XX
)

;; Virtualization
(deflayermap (spc+modV_layer)
  v $action_modV+modV
  _ XX
)

;; Warnings
(deflayermap (spc+modW_layer)
  w $action_modW+modW
  _ XX
)

;; Extensions
(deflayermap (spc+modX_layer)
  x $action_modX+modX
  _ XX
)

;; History
(deflayermap (spc+modY_layer)
  y $action_modY+modY

  $mod;      $action_modY+mod;
  $search    $action_modY+search
)

;; Tests
(deflayermap (spc+modZ_layer)
  z $action_modZ+modZ
  _ XX
)

;; Commands
(deflayermap (spc+mod;_layer)
  ; $action_mod;+mod;
  _ XX
)

;; Registries
(deflayermap (spc+mod'_layer)
  ' $action_mod'+mod'
  _ XX
)

;; Settings
(deflayermap (spc+mod,_layer)
  , $action_mod,+mod,
  _ XX
)

;; Tags
(deflayermap (spc+mod._layer)
  . $action_mod.+mod.
  _ XX
)

;; Help
(deflayermap (spc+mod/_layer)
  / $action_mod/+mod/
  _ XX
)

;; Compare
(deflayermap (spc+mod\_layer)
  \ (t! sft_switch $action_mod\+mod\ $action_mod\+lsft+mod\ $action_mod\+lsft+mod\)

  j $action_mod\+j
  k $action_mod\+k

  o $action_mod\+o
  p $action_mod\+p

  ent $action_mod\+ent
  _ XX
) ;;""

;; Backlinks
(deflayermap (spc+mod[_layer)
  [ $action_mod[+mod[
  _ XX
) ;;""

;; Outlinks
(deflayermap (spc+mod]_layer)
  ] $action_mod]+mod]
  _ XX
) ;;""

;; 
(deflayermap (spc+mod`_layer)
  ` $action_mod`+mod`
  _ XX
)

;; 
(deflayermap (spc+mod-_layer)
  - $action_mod-+mod-
  _ XX
)

;; Format
(deflayermap (spc+mod=_layer)
  = $action_mod=+mod=
  _ XX
)

