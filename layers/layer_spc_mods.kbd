;; Activates corresponding layer.
(deflayermap (spc_mods_layer)
  a (on-press press-vkey vk_modA)
  b (on-press press-vkey vk_modB)
  c (on-press press-vkey vk_modC)
  d (on-press press-vkey vk_modD)
  e (on-press press-vkey vk_modE)
  f (on-press press-vkey vk_modF)
  g (on-press press-vkey vk_modG)
  h (on-press press-vkey vk_modH)
  i (on-press press-vkey vk_modI)
  j (on-press press-vkey vk_modJ)
  k (on-press press-vkey vk_modK)
  l (on-press press-vkey vk_modL)
  m (on-press press-vkey vk_modM)
  n (on-press press-vkey vk_modN)
  o (on-press press-vkey vk_modO)
  p (on-press press-vkey vk_modP)
  q (on-press press-vkey vk_modQ)
  r (on-press press-vkey vk_modR)
  s (on-press press-vkey vk_modS)
  t (on-press press-vkey vk_modT)
  u (on-press press-vkey vk_modU)
  v (on-press press-vkey vk_modV)
  w (on-press press-vkey vk_modW)
  x (on-press press-vkey vk_modX)
  y (on-press press-vkey vk_modY)
  z (on-press press-vkey vk_modZ)
  ; (on-press press-vkey vk_mod;)
  ' (on-press press-vkey vk_mod')
  , (on-press press-vkey vk_mod,)
  . (on-press press-vkey vk_mod.)
  / (on-press press-vkey vk_mod/)
  \ (on-press press-vkey vk_mod\)
  [ (on-press press-vkey vk_mod[)
  ] (on-press press-vkey vk_mod])
  ` (on-press press-vkey vk_mod`)
  - (on-press press-vkey vk_mod-)
  = (on-press press-vkey vk_mod=)
  0 (on-press press-vkey vk_mod0)
  1 (on-press press-vkey vk_mod1)
  2 (on-press press-vkey vk_mod2)
  3 (on-press press-vkey vk_mod3)
  4 (on-press press-vkey vk_mod4)
  5 (on-press press-vkey vk_mod5)
  6 (on-press press-vkey vk_mod6)
  7 (on-press press-vkey vk_mod7)
  8 (on-press press-vkey vk_mod8)
  9 (on-press press-vkey vk_mod9) ;;""
) ;;""
