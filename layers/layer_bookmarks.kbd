  g $action_bookmarks+g+rsft
  h $action_bookmarks+h+rsft
  i $action_bookmarks+i+rsft
  j $action_bookmarks+j+rsft
  k $action_bookmarks+k+rsft
  l $action_bookmarks+l+rsft
  m $action_bookmarks+m+rsft
  n $action_bookmarks+n+rsft
  o $action_bookmarks+o+rsft
  p $action_bookmarks+p+rsft
  q $action_bookmarks+q+rsft
  r $action_bookmarks+r+rsft
  s $action_bookmarks+s+rsft
  t $action_bookmarks+t+rsft
  u $action_bookmarks+u+rsft
  v $action_bookmarks+v+rsft
  w $action_bookmarks+w+rsft
