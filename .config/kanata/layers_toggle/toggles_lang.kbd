(defvar
  ;; Lang layer
  toggle_alt_chars         (multi (on-press toggle-virtualkey vk_alt_chars) (switch
                             ((input virtual vk_alt_chars)) (push-msg "NOTIFY:US keyboard")  break
                             ()                             (push-msg "NOTIFY:ESP keyboard") break
                           ))

  toggle_lang_layer        (t! toggle_layer lang_layer)
)

